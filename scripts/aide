#!/usr/bin/env python3
"""Repo-root entrypoint for AIDE Harness v0."""

from __future__ import annotations

import sys
from pathlib import Path


def main() -> int:
    repo_root = Path(__file__).resolve().parent.parent
    sys.path.insert(0, str(repo_root))

    from core.harness.aide_harness import main as harness_main

    return harness_main(default_repo_root=repo_root)


if __name__ == "__main__":
    raise SystemExit(main())
